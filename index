<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>La Libre | Slow Collection</title>
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.344.0/dist/umd/lucide.min.js"></script>
    <style>
        :root {
            --bg-color: #ffffff;
            --text-color: #1a1a1a;
            --accent-color: #707070;
            --light-gray: #f9f9f9;
            --overlay-bg: rgba(0, 0, 0, 0.4);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2rem 4%;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            background: white;
            z-index: 100;
        }

        .logo {
            font-family: "Didot", "Bodoni MT", "Cinzel", serif;
            font-size: 1.8rem;
            letter-spacing: 0.3rem;
            text-transform: uppercase;
            font-weight: 400;
        }

        nav a {
            text-decoration: none;
            color: var(--text-color);
            margin: 0 1.5rem;
            font-size: 0.9rem;
            letter-spacing: 0.1rem;
            text-transform: uppercase;
        }

        .icons {
            display: flex;
            gap: 1.5rem;
            cursor: pointer;
        }

        .hero {
            text-align: center;
            padding: 5rem 1rem;
            background-color: var(--light-gray);
        }

        .hero h1 {
            font-family: serif;
            font-size: 2.5rem;
            font-weight: 300;
            margin-bottom: 1rem;
            letter-spacing: 0.1rem;
        }

        .hero p {
            font-style: italic;
            color: var(--accent-color);
            max-width: 600px;
            margin: 0 auto;
        }

        .products-container {
            max-width: 1200px;
            margin: 4rem auto;
            padding: 0 2rem;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 3rem;
        }

        .product-card {
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        .product-info {
            margin-top: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .product-title {
            font-size: 1rem;
            font-weight: 400;
            letter-spacing: 0.05rem;
        }

        .product-tagline {
            font-size: 0.85rem;
            color: var(--accent-color);
            margin-top: 0.2rem;
        }

        .product-price {
            font-weight: 500;
        }

        /* --- EMAIL POPUP STYLES --- */
        .popup-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: var(--overlay-bg);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.4s ease, visibility 0.4s ease;
            padding: 20px;
        }

        .popup-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .popup-modal {
            background: #ffffff;
            padding: 3rem 2.5rem;
            max-width: 450px;
            width: 100%;
            position: relative;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .popup-close {
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--accent-color);
        }

        .popup-modal h2 {
            font-family: serif;
            font-size: 1.8rem;
            font-weight: 300;
            letter-spacing: 0.1rem;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .popup-modal p {
            font-size: 0.9rem;
            color: var(--accent-color);
            margin-bottom: 2rem;
        }

        .popup-form input[type="email"] {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid #ccc;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            outline: none;
            text-align: center;
        }

        .popup-form input[type="email"]:focus {
            border-color: var(--text-color);
        }

        .popup-form button {
            width: 100%;
            padding: 0.9rem;
            background-color: var(--text-color);
            color: #fff;
            border: none;
            text-transform: uppercase;
            letter-spacing: 0.15rem;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.3s ease;
        }

        .popup-form button:hover {
            background-color: #333;
        }

        footer {
            text-align: center;
            padding: 4rem 1rem;
            border-top: 1px solid #eee;
            margin-top: 4rem;
            font-size: 0.85rem;
            color: var(--accent-color);
            letter-spacing: 0.05rem;
        }
    </style>
</head>
<body>

    <!-- Email Popup Modal -->
    <div class="popup-overlay" id="emailPopup">
        <div class="popup-modal">
            <button class="popup-close" id="closePopup">
                <i data-lucide="x" style="width: 18px; height: 18px;"></i>
            </button>
            <h2>La Libre</h2>
            <p>Join the slow movement. Subscribe to receive private collection updates and exclusive access.</p>
            <form class="popup-form" id="subscribeForm">
                <input type="email" placeholder="YOUR EMAIL" required>
                <button type="submit">Subscribe</button>
            </form>
        </div>
    </div>

    <header>
        <div class="logo">La Libre</div>
        <nav>
            <a href="#">Collection</a>
            <a href="#">Our Story</a>
            <a href="#">Lace Care</a>
        </nav>
        <div class="icons">
            <i data-lucide="search"></i>
            <i data-lucide="shopping-bag"></i>
        </div>
    </header>

    <section class="hero">
        <h1>Free Soul, Second Skin</h1>
        <p>Slow collection crafted in delicate lace. Designed to feel like nothing else.</p>
    </section>

    <main class="products-container">
        <div class="grid">
            <!-- Product 1 -->
            <div class="product-card">
                <div style="height: 400px; background: #eae5e2; display: flex; align-items: center; justify-content: center; color: #777;">
                    [ Insert White Lace Slip Image ]
                </div>
                <div class="product-info">
                    <div>
                        <h3 class="product-title">The Grace Lace Maxi</h3>
                        <p class="product-tagline">Slow Collection in White</p>
                    </div>
                    <span class="product-price">$140</span>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card">
                <div style="height: 400px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; color: #fff;">
                    [ Insert Black Silhouette Dress Image ]
                </div>
                <div class="product-info">
                    <div>
                        <h3 class="product-title">Noir Second Skin Dress</h3>
                        <p class="product-tagline">Premium Black Lace</p>
                    </div>
                    <span class="product-price">$165</span>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card">
                <div style="height: 400px; background: #f4f1ef; display: flex; align-items: center; justify-content: center; color: #777;">
                    [ Insert Lace Corset Top Image ]
                </div>
                <div class="product-info">
                    <div>
                        <h3 class="product-title">Amour Lace Bustier</h3>
                        <p class="product-tagline">Delicate French Trim</p>
                    </div>
                    <span class="product-price">$85</span>
                </div>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 LA LIBRE. ALL RIGHTS RESERVED.</p>
    </footer>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        const popup = document.getElementById('emailPopup');
        const closeBtn = document.getElementById('closePopup');
        const form = document.getElementById('subscribeForm');

        // Show popup after 3 seconds
        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                popup.classList.add('active');
            }, 3000); 
        });

        // Close popup logic
        closeBtn.addEventListener('click', () => {
            popup.classList.remove('active');
        });

        // Close popup if background overlay is clicked
        popup.addEventListener('click', (e) => {
            if(e.target === popup) {
                popup.classList.remove('active');
            }
        });

        // Form handling
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Thank you for subscribing to La Libre.');
            popup.classList.remove('active');
        });
    </script>
</body>
</html>
